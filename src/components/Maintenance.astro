---
const plans = [
  {
    name: 'Drift Start',
    matches: 'Passer Enkel-pakken',
    price: '349',
    features: [
      'Månedlig backup',
      'Sikkerhetsoppdateringer',
      'Bistand til innhold',
      'Fornøydhetsgaranti',
    ],
  },
  {
    name: 'Drift Standard',
    matches: 'Passer Bedrift-pakken',
    price: '499',
    features: [
      'Alt fra Drift Start',
      'Innholdsendringer · 3 t/mnd',
      'SEO-oppfølging',
      'Google Analytics-rapport',
    ],
  },
  {
    name: 'Drift Premium',
    matches: 'Passer Skreddersydd',
    price: '649',
    features: [
      'Alt fra Drift Standard',
      'Prioritert support',
      'Månedlig statusrapport',
      'Strategisk rådgivning',
    ],
  },
];
---

<section id="drift" class="aftercare section">
  <div class="container">
    <p class="eyebrow aftercare__eyebrow">
      <span class="aftercare__eyedot" aria-hidden="true"></span>
      Etter lansering
    </p>
    <h2 class="aftercare__heading">Vi holder nettsiden i form.</h2>
    <p class="aftercare__lead">
      En nettside er ikke ferdig når den lanseres. Den må holdes vedlike —
      oppdateringer, sikkerhet, små endringer underveis. Du velger selv
      om du vil gjøre det selv, eller la meg ta meg av det.
    </p>

    <div class="aftercare__grid">
      {plans.map((plan) => (
        <article class="dplan">
          <div class="dplan__head">
            <h3 class="dplan__name">{plan.name}</h3>
            <p class="dplan__match">{plan.matches}</p>
          </div>

          <div class="dplan__price">
            <span class="dplan__amount">{plan.price}</span>
            <span class="dplan__period">kr/mnd</span>
          </div>

          <ul class="dplan__features">
            {plan.features.map((feature) => (
              <li class="dplan__feature">
                <span class="dplan__tick" aria-hidden="true">
                  <svg viewBox="0 0 14 14" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 7l3 3 7-7" />
                  </svg>
                </span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="aftercare__hosting">
      <div class="hosting__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <ellipse cx="12" cy="5" rx="9" ry="3"/>
          <path d="M3 5v6c0 1.7 4 3 9 3s9-1.3 9-3V5"/>
          <path d="M3 11v6c0 1.7 4 3 9 3s9-1.3 9-3v-6"/>
        </svg>
      </div>
      <div class="hosting__body">
        <h4 class="hosting__title">Hosting (valgfritt)</h4>
        <p class="hosting__text">
          <strong>Business Web Hosting fra 940 kr/år</strong> —
          rask, sikker, norsk server. Eller bruk din egen — det er ditt valg.
        </p>
      </div>
    </div>

    <p class="aftercare__note">
      Alle abonnementer er månedlige og kan sies opp når som helst.
      Ingen bindingstid, ingen oppstartsgebyr.
    </p>
  </div>
</section>

<style>
  .aftercare {
    background-color: var(--color-bg-elevated);
  }

  .aftercare__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .aftercare__eyedot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .aftercare__heading {
    font-size: var(--text-h1);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-4);
    max-width: 20ch;
  }

  .aftercare__lead {
    font-size: var(--text-body-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    max-width: 44em;
    margin-bottom: var(--space-12);
  }

  /* —— Grid —— */
  .aftercare__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  /* —— Drift plan card (more compact than Pricing) —— */
  .dplan {
    display: flex;
    flex-direction: column;
    padding: var(--space-6) var(--space-6);
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform var(--duration-normal) var(--ease-out),
                border-color var(--duration-normal) var(--ease-out);
  }

  .dplan:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-strong);
  }

  .dplan__head {
    margin-bottom: var(--space-4);
  }

  .dplan__name {
    font-size: 1.125rem;
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-tight);
    margin-bottom: 2px;
  }

  .dplan__match {
    font-size: var(--text-small);
    color: var(--color-text-tertiary);
  }

  .dplan__price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    padding-bottom: var(--space-5);
    margin-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .dplan__amount {
    font-size: 1.75rem;
    font-weight: var(--weight-medium);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    font-feature-settings: 'tnum';
  }

  .dplan__period {
    font-size: var(--text-small);
    color: var(--color-text-tertiary);
    font-weight: var(--weight-medium);
  }

  .dplan__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .dplan__feature {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-small);
    line-height: var(--leading-snug);
    color: var(--color-text-secondary);
  }

  .dplan__tick {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    color: var(--color-accent);
    margin-top: 1px;
  }

  /* —— Hosting block —— */
  .aftercare__hosting {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-6);
  }

  .hosting__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: var(--radius-md);
  }

  .hosting__title {
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-tight);
    margin-bottom: 4px;
  }

  .hosting__text {
    font-size: var(--text-small);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    max-width: 60ch;
  }

  .hosting__text strong {
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
  }

  /* —— Note —— */
  .aftercare__note {
    font-size: var(--text-small);
    color: var(--color-text-tertiary);
    text-align: center;
    max-width: 56em;
    margin-inline: auto;
  }

  /* —— Responsive —— */
  @media (max-width: 860px) {
    .aftercare__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }

    .aftercare__hosting {
      flex-direction: column;
      gap: var(--space-3);
    }
  }
</style>
