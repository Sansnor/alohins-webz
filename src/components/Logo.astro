---
interface Props {
  size?: 'sm' | 'lg';
}

const { size = 'sm' } = Astro.props;
---

<a href="/" class={`logo logo--${size}`} aria-label="Alohins Webz — til forsiden">
  <svg
    class="logo__mark"
    viewBox="0 0 64 64"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <rect width="64" height="64" rx="14" fill="currentColor"/>
    <path
      d="M 16 51 L 32 14 L 48 51 M 22 38 L 42 38"
      stroke="var(--color-bg-base)"
      stroke-width="6"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
    />
    <circle cx="51" cy="13" r="5.5" fill="var(--color-accent)"/>
  </svg>
  <span class="logo__text">Alohins Webz</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-primary);
    font-weight: var(--weight-medium);
    letter-spacing: -0.015em;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .logo:hover {
    opacity: 0.8;
  }

  .logo__mark {
    display: block;
    flex-shrink: 0;
  }

  /* —— Small (Nav) —— */
  .logo--sm {
    gap: 10px;
    font-size: 1rem;
  }

  .logo--sm .logo__mark {
    width: 30px;
    height: 30px;
  }

  /* —— Large (Footer) —— */
  .logo--lg {
    gap: 12px;
    font-size: 1.125rem;
  }

  .logo--lg .logo__mark {
    width: 38px;
    height: 38px;
  }
</style>
