---
// ============================================
//  ABOUT — personlig fortelling, ikke faktablokk.
//  Tallene har flyttet inn i Stats-komponenten over.
// ============================================
---

<section id="om" class="about section">
  <div class="container">
    <div class="about__grid">

      <div class="about__intro">
        <p class="eyebrow about__eyebrow">
          <span class="about__eyedot" aria-hidden="true"></span>
          Om meg
        </p>
        <h2 class="about__heading">
          Hei, jeg er Oleg.
        </h2>
        <p class="about__lead">
          Fascinasjonen for web startet allerede i 1996.
          Til daglig jobber jeg med kirkemusikk i Fosen, men siden 2018
          har lidenskapen fått eget liv — å bygge nettsider for de jeg tror på.
        </p>
      </div>

      <div class="about__body">
        <p>
          Jeg jobber alene fra Rissa, og det gjør at du får direkte
          kontakt med personen som faktisk bygger nettsiden din.
          Ingen prosjektledere mellom oss, ingen overraskelser i fakturaen.
        </p>
        <p>
          Du betaler for det du trenger — og velger selv om du vil ha
          drift og hosting hos meg etterpå.
        </p>
        <p class="about__signature">
          <span class="about__signature-mark" aria-hidden="true">↘</span>
          Bygget med omhu fra Rissa, Trøndelag.
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-16);
    align-items: start;
  }

  /* —— Intro (left column) —— */
  .about__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .about__eyedot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .about__heading {
    font-size: clamp(2.25rem, 5vw, 3rem);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-6);
  }

  .about__lead {
    font-size: var(--text-body-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  /* —— Body (right column) —— */
  .about__body {
    font-size: var(--text-body);
    line-height: var(--leading-loose);
    color: var(--color-text-secondary);
    padding-top: var(--space-2);
  }

  .about__body p {
    margin-bottom: var(--space-6);
    max-width: 50ch;
  }

  .about__signature {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-6);
    margin-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-small);
    color: var(--color-text-tertiary);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .about__signature-mark {
    color: var(--color-accent);
    font-size: 1.25rem;
  }

  /* —— Responsive —— */
  @media (max-width: 860px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
