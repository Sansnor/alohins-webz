---
// ============================================
//  CONTACT DRAWER — sklir inn fra høyre, Cure-stil.
//
//  Trigger: legg data-open-contact på ENHVER knapp eller lenke.
//  Eksempel: <button data-open-contact>Start prosjekt</button>
//
//  Lukkes ved: Escape, klikk på overlay, eller lukk-knapp.
// ============================================
const FORMSPREE_ENDPOINT = ''; // ← Lim inn din Formspree URL her (se README)

const email = 'post@alohins-webz.no';
const phone = '+47 46 64 78 51';
const phoneLink = '+4746647851';

const formAction = FORMSPREE_ENDPOINT || `mailto:${email}`;
const formMethod = FORMSPREE_ENDPOINT ? 'POST' : 'GET';
---

<div class="drawer" id="contact-drawer" aria-hidden="true">
  <div class="drawer__overlay" data-close-contact aria-hidden="true"></div>

  <aside
    class="drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="drawer-title"
    tabindex="-1"
  >
    <header class="drawer__header">
      <div class="drawer__eyebrow">
        <span class="drawer__eyedot" aria-hidden="true"></span>
        Kontakt
      </div>
      <button
        type="button"
        class="drawer__close"
        data-close-contact
        aria-label="Lukk kontaktskjema"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M6 6l12 12M18 6l-12 12" />
        </svg>
      </button>
    </header>

    <div class="drawer__body">
      <h2 id="drawer-title" class="drawer__title">
        Klar til å starte<br />et prosjekt?
      </h2>
      <p class="drawer__lead">
        Fortell kort hva du trenger, så svarer jeg innen 24 timer.
        Første samtale er gratis og uforpliktende.
      </p>

      <div class="drawer__direct">
        <a href={`mailto:${email}`} class="drawer__direct-item">
          <span class="drawer__direct-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M3 7l9 6 9-6"/>
            </svg>
          </span>
          {email}
        </a>
        <a href={`tel:${phoneLink}`} class="drawer__direct-item">
          <span class="drawer__direct-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </span>
          {phone}
        </a>
      </div>

      <form class="drawer__form" action={formAction} method={formMethod}>
        <div class="field">
          <label for="d-name" class="field__label">Navn <span class="field__req">*</span></label>
          <input id="d-name" name="name" type="text" required autocomplete="name" class="field__input" placeholder="Ditt navn" />
        </div>

        <div class="field-row">
          <div class="field">
            <label for="d-email" class="field__label">E-post <span class="field__req">*</span></label>
            <input id="d-email" name="email" type="email" required autocomplete="email" class="field__input" placeholder="navn@bedrift.no" />
          </div>
          <div class="field">
            <label for="d-phone" class="field__label">Telefon</label>
            <input id="d-phone" name="phone" type="tel" autocomplete="tel" class="field__input" placeholder="+47 ..." />
          </div>
        </div>

        <div class="field">
          <label for="d-company" class="field__label">Bedrift, menighet eller prosjekt</label>
          <input id="d-company" name="company" type="text" autocomplete="organization" class="field__input" placeholder="Valgfritt" />
        </div>

        <div class="field">
          <label for="d-message" class="field__label">Hva trenger du hjelp med? <span class="field__req">*</span></label>
          <textarea id="d-message" name="message" required rows="5" class="field__textarea" placeholder="Kort om prosjektet, tidsramme eller spørsmål…"></textarea>
        </div>

        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="field__honeypot" aria-hidden="true" />
        <input type="hidden" name="_subject" value="Ny henvendelse fra alohins-webz.no" />

        <button type="submit" class="drawer__submit">
          Send melding
          <span class="drawer__submit-arrow" aria-hidden="true">↘</span>
        </button>

        <p class="drawer__note">
          Du får svar på e-post innen 24 timer.
          Ingen videresending, ingen nyhetsbrev.
        </p>

        <p class="drawer__error" data-error hidden>
          Noe gikk galt. Prøv igjen, eller send e-post direkte til
          <a href={`mailto:${email}`}>{email}</a>.
        </p>
      </form>

      {/* Success state — vises etter vellykket innsending */}
      <div class="drawer__success" data-success hidden aria-live="polite">
        <div class="drawer__success-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5" />
          </svg>
        </div>
        <h3 class="drawer__success-title">Takk!</h3>
        <p class="drawer__success-text">
          Meldingen er sendt. Jeg svarer som regel innen 24 timer —
          ofte raskere på hverdager.
        </p>
        <button type="button" class="drawer__submit" data-close-contact>
          Lukk
        </button>
      </div>
    </div>
  </aside>
</div>

<style>
  /* ——— Container & overlay ——— */
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    visibility: hidden;
  }

  .drawer[aria-hidden="false"] {
    pointer-events: auto;
    visibility: visible;
  }

  .drawer__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(26, 26, 26, 0);
    transition: background-color 360ms var(--ease-out);
  }

  .drawer[aria-hidden="false"] .drawer__overlay {
    background-color: rgba(26, 26, 26, 0.55);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  /* ——— Panel ——— */
  .drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: min(520px, 100%);
    background-color: var(--color-bg-inverse);
    color: var(--color-text-inverse);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 420ms var(--ease-out);
    box-shadow: -20px 0 60px -20px rgba(0, 0, 0, 0.4);
  }

  .drawer[aria-hidden="false"] .drawer__panel {
    transform: translateX(0);
  }

  /* ——— Header ——— */
  .drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6) var(--space-8);
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
    flex-shrink: 0;
  }

  .drawer__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-inverse);
    opacity: 0.7;
  }

  .drawer__eyedot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid rgba(250, 247, 242, 0.15);
    border-radius: var(--radius-full);
    color: var(--color-text-inverse);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }

  .drawer__close:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    transform: rotate(90deg);
  }

  /* ——— Body (scrollable) ——— */
  .drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-8);
  }

  .drawer__title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-4);
    color: var(--color-text-inverse);
  }

  .drawer__lead {
    font-size: var(--text-body);
    line-height: var(--leading-normal);
    color: rgba(250, 247, 242, 0.7);
    margin-bottom: var(--space-8);
  }

  /* ——— Direct contact strip ——— */
  .drawer__direct {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
  }

  .drawer__direct-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-small);
    color: rgba(250, 247, 242, 0.85);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .drawer__direct-item:hover {
    color: var(--color-accent);
  }

  .drawer__direct-icon {
    color: var(--color-accent);
  }

  /* ——— Form ——— */
  .drawer__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .field__label {
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.55);
  }

  .field__req {
    color: var(--color-accent);
  }

  .field__input,
  .field__textarea {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--color-text-inverse);
    background-color: rgba(250, 247, 242, 0.04);
    border: 1px solid rgba(250, 247, 242, 0.12);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    width: 100%;
    transition: border-color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .field__input::placeholder,
  .field__textarea::placeholder {
    color: rgba(250, 247, 242, 0.3);
  }

  .field__input:focus,
  .field__textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    background-color: rgba(250, 247, 242, 0.06);
    box-shadow: 0 0 0 3px rgba(199, 91, 60, 0.2);
  }

  .field__textarea {
    resize: vertical;
    min-height: 110px;
    line-height: var(--leading-normal);
    font-family: var(--font-sans);
  }

  .field__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  /* ——— Submit ——— */
  .drawer__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--color-text-inverse);
    background-color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }

  .drawer__submit:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .drawer__submit-arrow {
    font-size: 1.1em;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .drawer__submit:hover .drawer__submit-arrow {
    transform: translate(2px, -2px);
  }

  .drawer__note {
    font-size: var(--text-small);
    line-height: var(--leading-snug);
    color: rgba(250, 247, 242, 0.5);
    margin-top: var(--space-3);
  }

  /* ——— Error message under form ——— */
  .drawer__error {
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background-color: rgba(199, 91, 60, 0.12);
    border: 1px solid rgba(199, 91, 60, 0.35);
    border-radius: var(--radius-md);
    font-size: var(--text-small);
    line-height: var(--leading-snug);
    color: var(--color-text-inverse);
  }

  .drawer__error a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* ——— Success state (replaces form) ——— */
  .drawer__success {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding-top: var(--space-8);
  }

  .drawer__success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background-color: rgba(74, 190, 111, 0.15);
    color: #4ABE6F;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-2);
  }

  .drawer__success-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-inverse);
    margin: 0;
  }

  .drawer__success-text {
    font-size: var(--text-body);
    line-height: var(--leading-normal);
    color: rgba(250, 247, 242, 0.7);
    margin: 0;
  }

  /* When success is shown, hide the form */
  .drawer__form[hidden] {
    display: none;
  }

  /* ——— Submit button disabled state ——— */
  .drawer__submit[disabled] {
    opacity: 0.6;
    cursor: wait;
  }

  /* ——— Scrollbar styling for the drawer body ——— */
  .drawer__body::-webkit-scrollbar {
    width: 6px;
  }
  .drawer__body::-webkit-scrollbar-thumb {
    background-color: rgba(250, 247, 242, 0.15);
    border-radius: 3px;
  }

  /* ——— Lock body scroll when drawer is open ——— */
  :global(body.drawer-open) {
    overflow: hidden;
  }

  /* ——— Mobile ——— */
  @media (max-width: 540px) {
    .drawer__header,
    .drawer__body {
      padding-inline: var(--space-6);
    }

    .field-row {
      grid-template-columns: 1fr;
    }
  }

  /* ——— Respekter brukere med redusert bevegelse ——— */
  @media (prefers-reduced-motion: reduce) {
    .drawer__panel,
    .drawer__overlay {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const drawer = document.getElementById('contact-drawer');
    if (!drawer) return;

    const panel = drawer.querySelector<HTMLElement>('.drawer__panel');
    const form = drawer.querySelector<HTMLFormElement>('.drawer__form');
    const successBlock = drawer.querySelector<HTMLElement>('[data-success]');
    const errorBlock = drawer.querySelector<HTMLElement>('[data-error]');
    const submitBtn = drawer.querySelector<HTMLButtonElement>('.drawer__submit');
    const openTriggers = document.querySelectorAll<HTMLElement>('[data-open-contact]');
    const closeTriggers = drawer.querySelectorAll<HTMLElement>('[data-close-contact]');

    let lastFocused: HTMLElement | null = null;

    const resetForm = () => {
      if (!form || !successBlock || !errorBlock) return;
      form.hidden = false;
      successBlock.hidden = true;
      errorBlock.hidden = true;
      form.reset();
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Send melding <span class="drawer__submit-arrow" aria-hidden="true">↘</span>';
      }
    };

    const openDrawer = (e?: Event) => {
      if (e) e.preventDefault();
      lastFocused = document.activeElement as HTMLElement;
      drawer.setAttribute('aria-hidden', 'false');
      document.body.classList.add('drawer-open');
      requestAnimationFrame(() => {
        const firstInput = drawer.querySelector<HTMLElement>('input:not([type="hidden"]), textarea, button');
        if (firstInput) firstInput.focus();
      });
    };

    const closeDrawer = () => {
      drawer.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('drawer-open');
      if (lastFocused) lastFocused.focus();
      // Reset form etter at panelet er lukket, så brukeren ikke ser hoppet
      setTimeout(resetForm, 500);
    };

    openTriggers.forEach((t) => t.addEventListener('click', openDrawer));
    closeTriggers.forEach((t) => t.addEventListener('click', closeDrawer));

    // Escape lukker
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') {
        closeDrawer();
      }
    });

    // Enkel focus trap
    drawer.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key !== 'Tab' || !panel) return;
      const focusables = panel.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]):not([hidden]), input:not([disabled]):not([type="hidden"]), textarea:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])'
      );
      // Filter ut elementer som er skjult (i hidden-container)
      const visible = Array.from(focusables).filter((el) => {
        return el.offsetParent !== null;
      });
      if (visible.length === 0) return;
      const first = visible[0];
      const last = visible[visible.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    // ——— AJAX form submission ———
    // Hvis action peker på Formspree (https), send med fetch og vis success
    // uten å forlate siden. Hvis action er mailto, la nettleseren håndtere det.
    if (form && submitBtn && successBlock && errorBlock) {
      form.addEventListener('submit', async (e) => {
        const action = form.getAttribute('action') || '';
        // Mailto eller annet ikke-http → la nettleseren håndtere som vanlig
        if (!action.startsWith('http')) return;

        e.preventDefault();
        errorBlock.hidden = true;

        // Loading state
        submitBtn.disabled = true;
        submitBtn.innerHTML = 'Sender…';

        try {
          const formData = new FormData(form);
          const response = await fetch(action, {
            method: 'POST',
            body: formData,
            headers: { Accept: 'application/json' },
          });

          if (response.ok) {
            // Suksess — gjem skjema, vis takk-blokk
            form.hidden = true;
            successBlock.hidden = false;
            // Flytt fokus til Lukk-knappen for tilgjengelighet
            const closeBtn = successBlock.querySelector<HTMLElement>('button');
            if (closeBtn) closeBtn.focus();
          } else {
            // Server svarte med feil
            throw new Error(`HTTP ${response.status}`);
          }
        } catch (err) {
          // Vis feilmelding, la skjemaet stå slik at brukeren kan prøve igjen
          errorBlock.hidden = false;
          submitBtn.disabled = false;
          submitBtn.innerHTML = 'Send melding <span class="drawer__submit-arrow" aria-hidden="true">↘</span>';
        }
      });
    }
  })();
</script>
