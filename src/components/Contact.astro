---
// ============================================
//  CONTACT — kort CTA-blokk som åpner drawer.
//  Selve skjemaet bor i ContactDrawer.astro.
// ============================================
---

<section id="kontakt" class="contact section">
  <div class="container">
    <div class="contact__card">
      <p class="eyebrow contact__eyebrow">
        <span class="contact__eyedot" aria-hidden="true"></span>
        Kontakt
      </p>

      <h2 class="contact__heading">
        Klar til å starte<br />et prosjekt?
      </h2>

      <p class="contact__lead">
        Fortell kort hva du trenger — jeg svarer innen 24 timer.
        Første samtale er alltid gratis og uforpliktende.
      </p>

      <button type="button" class="contact__cta" data-open-contact>
        Send melding
        <span class="contact__cta-arrow" aria-hidden="true">↘</span>
      </button>

      <p class="contact__alt">
        eller skriv direkte til
        <a href="mailto:post@alohins-webz.no">post@alohins-webz.no</a>
        ·
        <a href="tel:+4746647851">+47 46 64 78 51</a>
      </p>
    </div>
  </div>
</section>

<style>
  .contact__card {
    background-color: var(--color-bg-inverse);
    color: var(--color-text-inverse);
    border-radius: var(--radius-lg);
    padding: clamp(3rem, 8vw, 6rem) clamp(2rem, 5vw, 4rem);
    text-align: center;
    overflow: hidden;
    position: relative;
  }

  /* Subtle accent glow in the background */
  .contact__card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 70% 50%,
      rgba(199, 91, 60, 0.18),
      transparent 60%
    );
    pointer-events: none;
  }

  .contact__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    justify-content: center;
    margin-bottom: var(--space-6);
    color: var(--color-text-inverse);
    opacity: 0.7;
    position: relative;
  }

  .contact__eyedot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .contact__heading {
    font-size: clamp(2.25rem, 5.5vw, 3.5rem);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    margin-bottom: var(--space-6);
    color: var(--color-text-inverse);
    position: relative;
    text-wrap: balance;
  }

  .contact__lead {
    font-size: var(--text-body-lg);
    line-height: var(--leading-normal);
    color: rgba(250, 247, 242, 0.7);
    max-width: 40ch;
    margin: 0 auto var(--space-10);
    position: relative;
  }

  /* —— Big CTA button —— */
  .contact__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    font-family: var(--font-sans);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-medium);
    color: var(--color-text-inverse);
    background-color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-full);
    cursor: pointer;
    position: relative;
    transition: background-color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .contact__cta:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 16px 40px -12px rgba(199, 91, 60, 0.5);
  }

  .contact__cta-arrow {
    font-size: 1.2em;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .contact__cta:hover .contact__cta-arrow {
    transform: translate(3px, -3px);
  }

  .contact__alt {
    margin-top: var(--space-6);
    font-size: var(--text-small);
    color: rgba(250, 247, 242, 0.55);
    position: relative;
  }

  .contact__alt a {
    color: rgba(250, 247, 242, 0.85);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .contact__alt a:hover {
    color: var(--color-accent);
  }
</style>
