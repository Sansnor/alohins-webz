---
const email = 'post@alohins-webz.no';
const phone = '+47 46 64 78 51';
const phoneLink = '+4746647851';

// Simple mailto subject and body for the CTA button
const mailtoLink = `mailto:${email}?subject=${encodeURIComponent('Forespørsel om nettside')}&body=${encodeURIComponent('Hei Oleg,\n\nJeg er interessert i å snakke om et prosjekt.\n\n')}`;
---

<section id="kontakt" class="contact section">
  <div class="container">
    <div class="contact__card">

      <div class="contact__intro">
        <p class="eyebrow contact__eyebrow">
          <span class="contact__eyedot" aria-hidden="true"></span>
          Kontakt
        </p>
        <h2 class="contact__heading">
          Klar til å starte<br />et prosjekt?
        </h2>
        <p class="contact__lead">
          Send meg en melding eller ring direkte.
          Jeg svarer som regel innen 24 timer.
          Første samtale er alltid gratis og uforpliktende.
        </p>
      </div>

      <div class="contact__methods">
        <a href={mailtoLink} class="method">
          <div class="method__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M3 7l9 6 9-6"/>
            </svg>
          </div>
          <div class="method__body">
            <div class="method__label">E-post</div>
            <div class="method__value">{email}</div>
          </div>
          <div class="method__arrow" aria-hidden="true">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 11L11 5M11 5H6M11 5V10" />
            </svg>
          </div>
        </a>

        <a href={`tel:${phoneLink}`} class="method">
          <div class="method__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <div class="method__body">
            <div class="method__label">Telefon</div>
            <div class="method__value">{phone}</div>
          </div>
          <div class="method__arrow" aria-hidden="true">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 11L11 5M11 5H6M11 5V10" />
            </svg>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  .contact__card {
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  /* —— Intro —— */
  .contact__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .contact__eyedot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .contact__heading {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-4);
  }

  .contact__lead {
    font-size: var(--text-body);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    max-width: 36ch;
  }

  /* —— Methods —— */
  .contact__methods {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .method {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    transition: background-color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }

  .method:hover {
    background-color: var(--color-bg-base);
    border-color: var(--color-text-primary);
    transform: translateY(-2px);
  }

  .method__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: var(--radius-full);
  }

  .method__body {
    flex: 1;
    min-width: 0;
  }

  .method__label {
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 2px;
  }

  .method__value {
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    letter-spacing: -0.005em;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .method__arrow {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
    transition: color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }

  .method:hover .method__arrow {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }

  /* —— Responsive —— */
  @media (max-width: 860px) {
    .contact__card {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
